# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Threads test account (PoC: 自有測試帳號，切勿用客戶帳號)
THREADS_USERNAME=your_test_handle

# Playwright
# 持久化登入態的 user-data-dir，避免每次重新登入觸發風控
PW_PROFILE_DIR=.cdp-profile
PW_HEADLESS=false

# 海巡節流（可調）
SCOUT_MAX_POSTS_PER_MIN=8
SCOUT_SESSION_MAX_HOURS=3
REVIEW_BATCH_MAX=15
REVIEW_APPROVAL_RATE_WARN=0.95

# 海巡內部調校（D16 護城河，僅供開發者調校 AI 海巡行為；不開放使用者）
# 預設值在 src/backend/scoutTuning.ts；設了以下變數即覆寫。對 UI 觸發與 dev 觸發皆生效。
SCOUT_TARGET_CANDIDATES=10   # 單輪最多收集幾篇候選（補量迴圈每輪會再壓成缺額）
SCOUT_MAX_SCROLLS=30         # 單輪最多捲動次數
SCOUT_MAX_SCANNED=60         # 單輪最多掃描幾張貼文卡

# 發布 Poster 內部調校（D16；不開放使用者）
# 預設值在 src/backend/posterTuning.ts；設了以下變數即覆寫。
POSTER_DRY_RUN=1               # 1=不真的送出 DOM（僅跑流程+log），0=實機送出。MVP 預設 1。
POSTER_COOLDOWN_MIN_MIN=4      # 兩篇之間最少分鐘
POSTER_COOLDOWN_MIN_MAX=11     # 兩篇之間最多分鐘
POSTER_MAX_PER_SESSION=10      # 單 session 最多發幾篇
POSTER_SESSION_HOURS=3         # session 最長持續小時
POSTER_POLL_MS=5000            # 掃 approved 週期（ms）
POSTER_PREVIEW_TIMEOUT_MIN=15  # dry-run 預覽等待人工確認逾時分鐘
